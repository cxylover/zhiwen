# Database
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/zhiguang?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Elasticsearch
ELASTICSEARCH_URIS=http://localhost:9201
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Canal
CANAL_HOST=localhost
CANAL_PORT=11111
CANAL_DESTINATION=example
CANAL_USERNAME=
CANAL_PASSWORD=
CANAL_FILTER=zhiguang\.outbox

# JWT keys. Prefer local files that are not committed.
JWT_PRIVATE_KEY=classpath:keys/private.pem
JWT_PUBLIC_KEY=classpath:keys/public.pem

# AI providers
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
FEATURE_RAG_ENABLED=false

# OSS
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_PUBLIC_DOMAIN=
